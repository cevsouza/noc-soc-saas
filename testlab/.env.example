# Copie este arquivo para ".env" e cole a chave gerada na plataforma.
# (Cockpit → Configuração MSP → Como Conectar → selecione o tenant "noc" → Gerar chave)

# URL base da plataforma (produção)
NOC_BASE=https://noc-soc-saas-production.up.railway.app

# Chave de ingestão do tenant de teste. Começa com "noc_".
NOC_TOKEN=cole_sua_chave_aqui

# Credenciais do Grafana local (troque se quiser)
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
